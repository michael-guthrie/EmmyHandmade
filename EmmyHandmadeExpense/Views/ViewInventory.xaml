<Window x:Class="AssetManager.Views.ViewInventory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager.Views"
        mc:Ignorable="d"
        Title="View Inventory" Height="600" Width="700"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ViewInventoryViewModel}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-3-Inventory-maintenance.ico">
    <Window.InputBindings>
        <KeyBinding Key="P" Modifiers="Ctrl" Command="{Binding PrintCommand}"/>
    </Window.InputBindings>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="Print" InputGestureText="Ctrl+P" Command="{Binding PrintCommand}"/>
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" Name="InventoryGrid" ItemsSource="{Binding Items}" IsReadOnly="True" AutoGenerateColumns="False" VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Item Name" Binding="{Binding Name, Mode=OneWay}"/>
                <DataGridTextColumn Header="Quantity (approx.)" Binding="{Binding Quantity, Mode=OneWay, StringFormat=0.0#####}">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Units" Binding="{Binding UnitOfMeasure, Mode=OneWay}"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=OneWay, StringFormat=N2}">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="History">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View" Click="ViewHistoryButton_Click" DataContext="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Orientation="Horizontal">
            <TextBlock Text="Display Inventory as of" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding InventoryAsOfDate, Mode=TwoWay}" Margin="4" VerticalAlignment="Center"/>
            <Button Content="Update Display" Command="{Binding CalculateAtDate}" Margin="4"/>
            <TextBlock Text="Total Value:" Margin="30,0,4,0" VerticalAlignment="Center"/>
            <TextBox Text="{Binding TotalValue, Mode=OneWay, StringFormat=0.00####}" IsReadOnly="True" MinWidth="60" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.RowSpan="99" Background="Gray" Opacity="0.6" Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}" />
        <TextBlock Grid.RowSpan="99" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" FontStyle="Oblique" FontWeight="Bold" Text="Loading..."
                   Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}"/>
    </Grid>
</Window>
