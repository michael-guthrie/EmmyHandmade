<Window x:Class="AssetManager.Views.ViewProducts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager.Views"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        mc:Ignorable="d"
        Title="View Products" Height="500" Width="700"
        d:DataContext="{d:DesignInstance Type=vm:ViewProductViewModel}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-3-Product-sales-report.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" ItemsSource="{Binding Products}" VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Product.Name}" Width="1*"/>
                <DataGridTextColumn Binding="{Binding TotalProduced, StringFormat=0.0#####}" Width="60">
                    <DataGridTextColumn.Header>
                        <TextBlock>
                            Total
                            <LineBreak/>
                            Produced
                        </TextBlock>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Total Out" Binding="{Binding TotalOut, Mode=OneWay, StringFormat=0.0#####}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="Remain" Binding="{Binding Remaining, Mode=OneWay, StringFormat=0.0#####}" Width="60" IsReadOnly="True"/>
                <DataGridTextColumn Header="Cost Per" Binding="{Binding CostPer, Mode=OneWay, StringFormat=0.0#####}" Width="60" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Save" Command="{Binding SaveCommand}" Margin="2" Width="80"/>
            <Button Content="Close" Click="CloseButton_Click" Margin="2" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
