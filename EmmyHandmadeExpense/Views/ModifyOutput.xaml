<Window x:Class="AssetManager.Views.ModifyOutput"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:helpers="clr-namespace:AssetManager.Helpers"
        xmlns:local="clr-namespace:AssetManager.Views"
        xmlns:uc="clr-namespace:AssetManager.Views.UserControls"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        mc:Ignorable="d"
        Title="Output Record" Height="500" Width="500"
        d:DataContext="{d:DesignInstance Type=vm:OutputViewModelBase}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-3-Packing.ico">
    <Grid>
        <Grid.Resources>
            <Style TargetType="DatePicker">
                <Setter Property="Margin" Value="4"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="Margin" Value="4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="4"/>
            </Style>
            <FrameworkElement x:Key="ProxyElement" DataContext="{Binding}"/>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Text="Date:"/>
        <DatePicker Grid.Row="0" Grid.Column="1" SelectedDate="{Binding OutRecord.Date}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="Bold" Text="Description:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OutRecord.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="48"
                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="Bold" Text="Total Sale:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding OutRecord.TotalSale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', StringFormat=0.00####}">
            <i:Interaction.Behaviors>
                <helpers:TextBoxInputBehavior InputMode="DecimalInput"/>
            </i:Interaction.Behaviors>
        </TextBox>

        <GroupBox Grid.Row="3" Grid.ColumnSpan="99" Margin="8" Header="Materials:" FontWeight="Bold">
            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding OutRecord.Materials}" CanUserAddRows="True" CanUserDeleteRows="True" VerticalScrollBarVisibility="Visible">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn ItemsSource="{Binding Items, Source={StaticResource ItemLookup}}" Header="Item"
                                            DisplayMemberPath="Value" SelectedValuePath="Key"
                                            SelectedValueBinding="{Binding InventoryItemId, UpdateSourceTrigger=PropertyChanged}" MinWidth="150"/>
                    <uc:DataGridDecimalColumn Header="Quantity" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=0.0#####}"/>
                    <DataGridTextColumn Header="Units" IsReadOnly="True" Binding="{Binding InventoryItemId, Converter={StaticResource ItemUnitConverter}}"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="4" Grid.ColumnSpan="99" Margin="8" Header="Products:" FontWeight="Bold" x:Name="ProductsGrid">
            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding OutRecord.Products}" CanUserAddRows="True" CanUserDeleteRows="True" VerticalScrollBarVisibility="Visible">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn Header="Item" ItemsSource="{Binding Products, Source={StaticResource ProductLookup}}"
                                            DisplayMemberPath="Value" SelectedValuePath="Key"
                                            SelectedValueBinding="{Binding BatchProductId, UpdateSourceTrigger=PropertyChanged}" MinWidth="150"/>
                    <uc:DataGridDecimalColumn Header="Quantity" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=0.0#####}"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="99" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Margin="4" Width="80" Command="{Binding SaveCommand}" />
            <Button Content="Close" Margin="4" Width="80" Click="CloseButton_Click" />
        </StackPanel>

        <Grid Grid.ColumnSpan="99" Grid.RowSpan="99" Background="Gray" Opacity="0.6"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}" />
        <TextBlock Grid.ColumnSpan="99" Grid.RowSpan="99" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" FontStyle="Oblique" FontWeight="Bold" Text="Loading..."
                   Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}"/>
    </Grid>
</Window>
