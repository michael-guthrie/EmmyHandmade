<Window x:Class="AssetManager.Views.OutputHistory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager.Views"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        mc:Ignorable="d"
        Title="OutputHistory" Height="400" Width="400"
        d:DataContext="{d:DesignInstance Type=vm:OutputHistoryViewModel}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-5-Catalog.ico">
    <Grid>
        <DataGrid AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Records}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="70"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="1*"/>
                <DataGridTextColumn Header="Total Sale" Binding="{Binding TotalSale, StringFormat=N2}" Width="70"/>
                <DataGridTemplateColumn Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View / Edit" DataContext="{Binding}" Click="ViewEditButton_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
