<Window x:Class="AssetManager.Views.BatchHistory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager.Views"
        mc:Ignorable="d"
        Title="BatchHistory" Height="500" Width="720"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:BatchHistoryViewModel}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-3-Order-history.ico">
    <Grid>
        <DataGrid AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding Batches}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Batch Date" Binding="{Binding BatchDate, StringFormat=d}" Width="70"/>
                <DataGridTextColumn Header="Product Name" Binding="{Binding Product.Name, StringFormat=d}" Width="1*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Binding="{Binding Cost}" Width="70">
                    <DataGridTextColumn.Header>
                        <TextBlock>
                            Estimated
                            <LineBreak/>
                            Cost
                        </TextBlock>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding UnitsProduced}" Width="70">
                    <DataGridTextColumn.Header>
                        <TextBlock>
                            Units
                            <LineBreak/>
                            Produced
                        </TextBlock>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View / Edit" DataContext="{Binding}" Click="ViewEditButton_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.ColumnSpan="99" Grid.RowSpan="99" Background="Gray" Opacity="0.6"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}" />
        <TextBlock Grid.ColumnSpan="99" Grid.RowSpan="99" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" FontStyle="Oblique" FontWeight="Bold" Text="Loading..."
                   Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}"/>
    </Grid>
</Window>
