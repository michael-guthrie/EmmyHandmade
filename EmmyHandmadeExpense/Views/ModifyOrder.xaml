<Window x:Class="AssetManager.Views.ModifyOrder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:local="clr-namespace:AssetManager.Views"
        xmlns:helpers="clr-namespace:AssetManager.Helpers"
        xmlns:uc="clr-namespace:AssetManager.Views.UserControls"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="500" Width="600"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:OrderViewModelBase}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-3-Product.ico">
    <Grid>
        <Grid.Resources>
            <Style TargetType="DatePicker">
                <Setter Property="Margin" Value="4"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="Margin" Value="4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="4"/>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Text="Source:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Source, Mode=TwoWay}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="Bold" Text="Order #:"/>
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding OrderNumber, Mode=TwoWay}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="Bold" Text="Link:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Link, Mode=TwoWay}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" FontWeight="Bold" Text="Shipping:"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Shipping, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', StringFormat=0.00####}">
            <i:Interaction.Behaviors>
                <helpers:TextBoxInputBehavior InputMode="DecimalInput"/>
            </i:Interaction.Behaviors>
        </TextBox>

        <TextBlock Grid.Row="4" Grid.Column="0" FontWeight="Bold" Text="Discount:"/>
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Discount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', StringFormat=0.00####}">
            <i:Interaction.Behaviors>
                <helpers:TextBoxInputBehavior InputMode="DecimalInput"/>
            </i:Interaction.Behaviors>
        </TextBox>

        <TextBlock Grid.Row="5" Grid.Column="0" FontWeight="Bold" Text="Tax:"/>
        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Tax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', StringFormat=0.00####}">
            <i:Interaction.Behaviors>
                <helpers:TextBoxInputBehavior InputMode="DecimalInput"/>
            </i:Interaction.Behaviors>
        </TextBox>

        <TextBlock Grid.Row="6" Grid.Column="0" FontWeight="Bold" Text="Ordered:"/>
        <DatePicker Grid.Row="6" Grid.Column="1" SelectedDate="{Binding DatePlaced}"/>

        <TextBlock Grid.Row="7" Grid.Column="0" FontWeight="Bold" Text="Received:"/>
        <DatePicker Grid.Row="7" Grid.Column="1" SelectedDate="{Binding DateReceived}"/>

        <GroupBox Grid.Row="8" Grid.ColumnSpan="99" Margin="8" Header="Items:" FontWeight="Bold">
            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding Items}" CanUserAddRows="True" CanUserDeleteRows="True" VerticalScrollBarVisibility="Visible">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn ItemsSource="{Binding Items, Source={StaticResource ItemLookup}}"
                                            DisplayMemberPath="Value" SelectedValuePath="Key"
                                            SelectedValueBinding="{Binding InventoryItemId, UpdateSourceTrigger=PropertyChanged}" MinWidth="150">
                        <DataGridComboBoxColumn.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Item"/>
                                <Button Grid.Column="1" Content="New" Padding="0" HorizontalAlignment="Center" Margin="1" Width="36" Height="24"
                                        Click="NewItemButton_Click"/>
                            </Grid>
                        </DataGridComboBoxColumn.Header>
                        <DataGridComboBoxColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </DataGridComboBoxColumn.HeaderStyle>
                    </DataGridComboBoxColumn>
                    <uc:DataGridDecimalColumn Header="Quantity" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=0.0#####}"/>
                    <DataGridComboBoxColumn Header="Units" ItemsSource="{Binding Units, Source={StaticResource UnitLookup}}"
                                            DisplayMemberPath="Value" SelectedValuePath="Key"
                                            SelectedValueBinding="{Binding OrderUOM, UpdateSourceTrigger=PropertyChanged}"/>
                    <uc:DataGridDecimalColumn Header="UnitPrice" Binding="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged, StringFormat=0.00####}"/>
                    <uc:DataGridDecimalColumn Header="Cost" Binding="{Binding Cost, UpdateSourceTrigger=PropertyChanged, StringFormat=0.00####}"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <TextBlock Grid.Row="9" Grid.Column="0" FontWeight="Bold" Text="Total Cost:"/>
        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding TotalCost, Mode=OneWay, StringFormat=0.00####}"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="99" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Margin="4" Width="80" Command="{Binding SaveCommand}" />
            <Button Content="Close" Margin="4" Width="80" Click="CloseButton_Click" />
        </StackPanel>

        <Grid Grid.ColumnSpan="99" Grid.RowSpan="99" Background="Gray" Opacity="0.6"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}" />
        <TextBlock Grid.ColumnSpan="99" Grid.RowSpan="99" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" FontStyle="Oblique" FontWeight="Bold" Text="Loading..."
                   Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}"/>
    </Grid>
</Window>
