<Window x:Class="AssetManager.Views.ViewInventoryItemHistory"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager.Views"
        mc:Ignorable="d"
        Title="View Inventory Item History" Height="400" Width="400"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:InventoryItemHistoryViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Text="Item: " FontWeight="Bold" Margin="2"/>
        <TextBox Grid.Column="1" IsReadOnly="True" HorizontalAlignment="Stretch" Margin="1" Text="{Binding InventoryItemName, Mode=OneWay}"/>

        <DataGrid Grid.ColumnSpan="99" Grid.Row="1" ItemsSource="{Binding ChangeEntries}" IsReadOnly="True" AutoGenerateColumns="False" VerticalScrollBarVisibility="Visible">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding ChangeDate, Mode=OneWay}"/>
                <DataGridTextColumn Header="Change" Binding="{Binding QuantityChange, Mode=OneWay, StringFormat=0.0#####}">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Quantity (approx.)" Binding="{Binding QuantityToDate, Mode=OneWay, StringFormat=0.0#####}">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Units" Binding="{Binding UnitOfMeasureName, Mode=OneWay}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
