<Window x:Class="AssetManager.Views.ModifyBatch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:local="clr-namespace:AssetManager.Views"
        xmlns:helpers="clr-namespace:AssetManager.Helpers"
        xmlns:uc="clr-namespace:AssetManager.Views.UserControls"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="500" Width="600"
        xmlns:vm="clr-namespace:AssetManager.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:BatchViewModelBase}"
        Icon="/AssetManager;component/Assets/Custom-Icon-Design-Pretty-Office-3-Ordering.ico">
    <Grid>
        <Grid.Resources>
            <Style TargetType="DatePicker">
                <Setter Property="Margin" Value="4"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="Margin" Value="4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="4"/>
            </Style>
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Text="Product Name:"/>
        <Grid Grid.Row="0" Grid.Column="1" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" ItemsSource="{Binding Products, Source={StaticResource ProductLookup}}" 
                      DisplayMemberPath="Value" SelectedValuePath="Key" SelectedValue="{Binding ProductId}"/>
            <Button Grid.Column="1" Content="New" Click="NewProductButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="Bold" Text="Date Made:"/>
        <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding BatchDate}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="Bold" Text="Batch Description:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Description, Mode=TwoWay}"/>

        <GroupBox Grid.Row="3" Grid.ColumnSpan="99" Margin="8" Header="Used Items:" FontWeight="Bold">
            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding UsedItems}" CanUserAddRows="True" CanUserDeleteRows="True"
                      VerticalScrollBarVisibility="Visible" RowDetailsVisibilityMode="Collapsed">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn Header="Item" ItemsSource="{Binding Items, Source={StaticResource ItemLookup}}"
                                            DisplayMemberPath="Value" SelectedValuePath="Key"
                                            SelectedValueBinding="{Binding InventoryItemId, UpdateSourceTrigger=PropertyChanged}" MinWidth="150" />
                    <uc:DataGridDecimalColumn Header="Quantity" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=0.0#######}"/>
                    <DataGridComboBoxColumn Header="Units" ItemsSource="{Binding Units, Source={StaticResource UnitLookup}}"
                                        DisplayMemberPath="Value" SelectedValuePath="Key" MinWidth="80"
                                        SelectedValueBinding="{Binding UnitOfMeasureId, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Default" Binding="{Binding InventoryItemId, Converter={StaticResource ItemUnitConverter}}" IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="Gray"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="% of Batch" Binding="{Binding Percent, Mode=OneWay, StringFormat=0.0#######}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding CostDisplay, Mode=OneWay}" IsReadOnly="True"/>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Cost Detail" Click="ShowCostDetail_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <uc:ItemHistory DataContext="{Binding CostHistory, Mode=OneWay}"/>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="4" Grid.ColumnSpan="99" Margin="8" Header="Loss Items:" FontWeight="Bold">
            <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding LossItems}" CanUserAddRows="True" CanUserDeleteRows="True"
                      VerticalScrollBarVisibility="Visible" RowDetailsVisibilityMode="Collapsed">
                <DataGrid.Columns>
                    <DataGridComboBoxColumn Header="Item" ItemsSource="{Binding Items, Source={StaticResource ItemLookup}}"
                                            DisplayMemberPath="Value" SelectedValuePath="Key"
                                            SelectedValueBinding="{Binding InventoryItemId, UpdateSourceTrigger=PropertyChanged}" MinWidth="150"/>
                    <uc:DataGridDecimalColumn Header="Quantity" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=0.0###}"/>
                    <DataGridComboBoxColumn Header="Units" ItemsSource="{Binding Units, Source={StaticResource UnitLookup}}"
                                        DisplayMemberPath="Value" SelectedValuePath="Key" MinWidth="80"
                                        SelectedValueBinding="{Binding UnitOfMeasureId, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Default" Binding="{Binding InventoryItemId, Converter={StaticResource ItemUnitConverter}}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding CostDisplay, Mode=OneWay}" IsReadOnly="True"/>
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Cost Detail" Click="ShowCostDetail_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <uc:ItemHistory DataContext="{Binding CostHistory, Mode=OneWay}"/>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </GroupBox>

        <Grid Grid.Row="5" Grid.ColumnSpan="99">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Text="Usage Cost:"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UsageCostDisplay}"/>

            <TextBlock Grid.Row="0" Grid.Column="3" FontWeight="Bold" Text="Loss Cost:"/>
            <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding LossCostDisplay}"/>

            <TextBlock Grid.Row="0" Grid.Column="6" FontWeight="Bold" Text="Total Cost:"/>
            <TextBlock Grid.Row="0" Grid.Column="7" Text="{Binding TotalCostDisplay}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="Bold" Text="Units Produced:"/>
            <TextBox Grid.Row="1"  Grid.Column="1" Text="{Binding UnitsProduced, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0.0#####, TargetNullValue=''}" MinWidth="90">
                <i:Interaction.Behaviors>
                    <helpers:TextBoxInputBehavior InputMode="DecimalInput"/>
                </i:Interaction.Behaviors>
            </TextBox>

            <TextBlock Grid.Row="1" Grid.Column="3" FontWeight="Bold" Text="Cost / Unit:"/>
            <TextBlock Grid.Row="1" Grid.Column="4" Text="{Binding PerUnitCostDisplay}"/>
        </Grid>
        
        <StackPanel Grid.Row="99" Grid.ColumnSpan="99" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Margin="4" Width="80" Command="{Binding SaveCommand}" />
            <Button Content="Close" Margin="4" Width="80" Click="CloseButton_Click" />
        </StackPanel>

        <Grid Grid.ColumnSpan="99" Grid.RowSpan="99" Background="Gray" Opacity="0.6"
              Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}" />
        <TextBlock Grid.ColumnSpan="99" Grid.RowSpan="99" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="24" FontStyle="Oblique" FontWeight="Bold" Text="Loading..."
                   Visibility="{Binding IsInitializing, Converter={StaticResource BoolToVisConverter}}"/>
    </Grid>
</Window>
