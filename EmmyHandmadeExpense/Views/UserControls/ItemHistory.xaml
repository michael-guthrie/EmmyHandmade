<UserControl x:Class="AssetManager.Views.UserControls.ItemHistory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AssetManager.Views.UserControls"
             xmlns:vm ="clr-namespace:AssetManager.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid d:DataContext="{d:DesignInstance Type=vm:ItemHistoryViewModel}">
        <DataGrid AutoGenerateColumns="False" ItemsSource="{Binding Items}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Used Adusted Units" Binding="{Binding Path=AdjustedQuantity, Mode=OneWay, StringFormat=N2}" />
                <DataGridTextColumn Header="Adjusted Price / Unit" Binding="{Binding Path=AdjustedUnitPrice, Mode=OneWay, StringFormat=N2}" />
                <DataGridTextColumn Header="Source" Binding="{Binding Path=Item.Order.Source, Mode=OneWay}" />
                <DataGridTextColumn Header="Order Date" Binding="{Binding Path=Item.Order.DatePlaced, Mode=OneWay}" />
                <DataGridTextColumn Header="Receipt Date" Binding="{Binding Path=Item.Order.DateReceived, Mode=OneWay}" />
                <DataGridTextColumn Header="Unit" Binding="{Binding Path=Item.UnitOfMeasure.Name, Mode=OneWay, StringFormat=N2}" />
                <DataGridTextColumn Header="Price / Unit" Binding="{Binding Path=Item.UnitPrice, Mode=OneWay, StringFormat=N2}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
