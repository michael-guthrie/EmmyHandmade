<Window x:Class="AssetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AssetManager"
        xmlns:uc="clr-namespace:AssetManager.Views.UserControls"
        mc:Ignorable="d"
        Title="Expense &amp; Inventory Management" Height="742" Width="800"
        Icon="Assets/Custom-Icon-Design-Pretty-Office-3-Inventory-maintenance.ico"
        Background="Gainsboro">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="99">
            <MenuItem Header="_File">
                <MenuItem Header="Export data..." Click="ExportDataMenuItem_Click"/>
                <MenuItem Header="E_xit" Click="AppExitMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Button Grid.Row="1" Grid.Column="0" Margin="1" Click="ViewInvButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Inventory-maintenance.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="View Current Inventory" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="1" Grid.Column="1" Margin="1" Click="AddOrderButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Package-Add.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Add Order" Margin="1" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="1" Grid.Column="2" Margin="1" Click="AddBatchButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Ordering.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Add Batch" Margin="1" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

        <Button Grid.Row="2" Grid.Column="0" Margin="1" Click="ManageItemsButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Item-configuration.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Manage Items" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="2" Grid.Column="1" Margin="1" Click="OrderHistoryButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Product-sales-report.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Order History" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="2" Grid.Column="2" Margin="1" Click="BatchHistoryButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Order-history.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Batch History" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

        <Button Grid.Row="3" Grid.Column="0" Margin="1" Click="ManageMiscExpButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Sales-by-Payment-Method-rep.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Miscellaneous Expenses" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <GroupBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="99" Header="Transaction Quick Lookup" BorderBrush="Black" BorderThickness="2">
            <StackPanel VerticalAlignment="Center">
                <uc:QuarterlyExpense Margin="4" HorizontalAlignment="Center"/>
                <uc:ExpenseDetail Grid.ColumnSpan="99" Margin="4" HorizontalAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <Button Grid.Row="4" Grid.Column="0" Margin="1" Click="ViewProductsButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Product-sales-report.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="View Products" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="4" Grid.Column="1" Margin="1" Click="AddOutputButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-3-Packing.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Add Sale / Loss / Other Output" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="4" Grid.Column="2" Margin="1" Click="OutputHistoryButton_Click">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="Assets/Custom-Icon-Design-Pretty-Office-5-Catalog.ico" Margin="2" HorizontalAlignment="Center" Height="128" Width="128"/>
                <TextBlock Text="Output History" Margin="2" HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

        <StatusBar Grid.Row="99" Grid.ColumnSpan="99">
            <StatusBarItem Content="I love you, Wife!  Wish you lots of luck in your business!"/>
        </StatusBar>
    </Grid>
</Window>
